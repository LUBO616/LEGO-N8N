# --- Postgres (para n8n) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# IMPORTANTE: llave larga (mínimo 32+ chars)
N8N_ENCRYPTION_KEY=replace_with_a_long_random_key

TZ=America/Mexico_City
